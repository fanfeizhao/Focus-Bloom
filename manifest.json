{
  "manifest_version": 3,
  "name": "Focus Bloom",
  "version": "1.3.0",
  "description": "A customizable focus timer with immersive break screens across all connected displays.",
  "permissions": [
    "storage",
    "alarms",
    "windows",
    "tabs",
    "system.display"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Bloom"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}